---
import Layout from '../layouts/Layout.astro';

const postsMap = import.meta.glob('../../notes/systes-and-backend/backend-from-first-principles/*.md', { eager: true });
const posts = Object.values(postsMap);

// Helper to extract numeric value for correct sorting
const getLectureNumber = (filepath) => {
  const filename = filepath.split('/').pop() || '';
  const match = filename.match(/LEC(\d+(?:\.\d+)?)/i);
  return match ? parseFloat(match[1]) : 999;
};

// Numerical sort & fetch active lectures
const activeLectures = posts
  .filter(post => {
    const filename = post.file.split('/').pop() || '';
    return filename.toLowerCase().startsWith('lec') && filename.endsWith('.md');
  })
  .sort((a, b) => getLectureNumber(a.file) - getLectureNumber(b.file))
  .map(post => {
    const filename = post.file.split('/').pop() || '';
    const slug = filename.replace(/\.md$/, '').toLowerCase();
    const headings = post.getHeadings();
    const h1 = headings.find(h => h.depth === 1);
    let title = h1 ? h1.text : filename.replace(/\.md$/, '');
    title = title.replace(/\s*[—-]\s*Lecture Notes/i, '');
    const lecNum = filename.match(/LEC(\d+(?:\.\d+)?)/i)?.[1] || '';
    return { title, slug, lecNum };
  });

const totalLectures = activeLectures.length;
---

<Layout 
  title="Home" 
  description="A premium developer notes portal, documenting backend engineering from first principles, databases, competitive programming, and low-level design patterns."
>
  <div class="dashboard-hero fade-in">
    <h1 class="main-title">
      Kaushal's <span class="neon-text-gradient">Study Notes</span>
    </h1>
  </div>

  <!-- Modules Grid -->
  <section class="modules-grid fade-in delay-100">
    <!-- Active Module: Systems and Backend -->
    <div class="module-card glass">
      <div class="card-glow"></div>
      <div class="card-header">
        <span class="module-icon">⚙️</span>
        <span class="path-hierarchy">notes/systes-and-backend/backend-from-first-principles</span>
      </div>
      <h2>Systems & Backend</h2>
      
      <div class="card-actions">
        <a href="/systems-and-backend/backend-from-first-principles/readme" class="action-btn primary-btn">
          <span>First Principles Backend</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      </div>
    </div>

    <!-- Skeleton Module: Databases -->
    <div class="module-card skeleton-card glass">
      <div class="card-header">
        <span class="module-icon">💾</span>
        <span class="path-hierarchy">notes/systes-and-backend/low-level-design</span>
      </div>
      <h2>Low-Level Design</h2>
      <div class="card-actions">
        <span class="action-btn secondary-btn disabled">
          <span>Skeleton Available</span>
        </span>
      </div>
    </div>

    <!-- Skeleton Module: Databases (Actual) -->
    <div class="module-card skeleton-card glass">
      <div class="card-header">
        <span class="module-icon">🗄️</span>
        <span class="path-hierarchy">notes/databases</span>
      </div>
      <h2>Databases &amp; CMU</h2>
      <div class="card-actions">
        <span class="action-btn secondary-btn disabled">
          <span>Skeleton Available</span>
        </span>
      </div>
    </div>

    <!-- Skeleton Module: DSA & CP -->
    <div class="module-card skeleton-card glass">
      <div class="card-header">
        <span class="module-icon">🧩</span>
        <span class="path-hierarchy">notes/dsa-and-cp</span>
      </div>
      <h2>DSA &amp; CP</h2>
      <div class="card-actions">
        <span class="action-btn secondary-btn disabled">
          <span>Skeleton Available</span>
        </span>
      </div>
    </div>

    <!-- Skeleton Module: Languages -->
    <div class="module-card skeleton-card glass">
      <div class="card-header">
        <span class="module-icon">☕</span>
        <span class="path-hierarchy">notes/languages</span>
      </div>
      <h2>Programming Languages</h2>
      <div class="card-actions">
        <span class="action-btn secondary-btn disabled">
          <span>Skeleton Available</span>
        </span>
      </div>
    </div>
  </section>




</Layout>

<style>
  /* Hero */
  .dashboard-hero {
    text-align: center;
    padding: 3rem 1.5rem;
    max-width: 800px;
    margin: 0 auto 3rem auto;
  }

  .badge {
    padding: 0.35rem 1rem !important;
    font-size: 0.8rem;
    margin-bottom: 1.5rem;
  }

  .main-title {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.04em;
    margin-bottom: 1.25rem;
  }

  .subtitle {
    font-size: 1.2rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Modules Grid */
  .modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .module-card {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s var(--ease-smooth), border-color 0.3s;
    border-radius: 12px;
  }

  .module-card:hover {
    transform: translateY(-4px);
    border-color: var(--border-color-hover);
  }

  .card-glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at center, hsla(192, 95%, 50%, 0.03) 0%, transparent 65%);
    pointer-events: none;
  }

  .card-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .path-hierarchy {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.03);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    border: 1px solid var(--border-color);
    word-break: break-all;
  }

  .module-icon {
    font-size: 1.75rem;
  }

  .status-pill {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  .active-pill {
    background: rgba(0, 229, 255, 0.1);
    color: var(--accent-cyan);
    border: 1px solid rgba(0, 229, 255, 0.2);
  }

  .skeleton-pill {
    background: rgba(157, 78, 221, 0.1);
    color: var(--accent-purple);
    border: 1px solid rgba(157, 78, 221, 0.2);
  }

  .module-card h2 {
    font-size: 1.5rem;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .card-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .module-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    padding: 0.75rem 1rem;
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    font-size: 0.85rem;
  }

  .meta-item {
    display: flex;
    justify-content: space-between;
  }

  .meta-item .label {
    color: var(--text-muted);
    font-weight: 600;
  }

  .meta-item .value {
    color: var(--accent-cyan);
    font-weight: 500;
  }

  .card-actions {
    display: flex;
    gap: 1rem;
    margin-top: auto;
  }

  .action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
  }

  .primary-btn {
    background: var(--grad-cyan-purple);
    color: #fff;
    box-shadow: var(--glow-cyan);
  }

  .primary-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 0 20px rgba(0, 229, 255, 0.25);
  }

  .secondary-btn {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
  }

  .secondary-btn:hover {
    border-color: var(--accent-purple);
    color: #fff;
  }

  .skeleton-card {
    opacity: 0.75;
  }

  .skeleton-card:hover {
    opacity: 1;
  }

  /* Syllabus Timeline */
  .syllabus-section {
    margin-bottom: 4rem;
  }

  .section-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .section-header h2 {
    font-size: 2rem;
    color: #fff;
    margin-bottom: 0.5rem;
  }

  .section-header p {
    color: var(--text-secondary);
  }

  .timeline-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  .timeline-node {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    transition: var(--transition-fast);
  }

  .timeline-node:hover {
    transform: scale(1.02);
    border-color: var(--accent-cyan);
    box-shadow: var(--glow-cyan);
    background: var(--bg-tertiary);
  }

  .node-number {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--accent-cyan);
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .node-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
  }

  .node-badge {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-bottom: 0.15rem;
  }

  .node-content h3 {
    font-size: 0.95rem;
    color: #fff;
    margin-bottom: 0.25rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .read-link {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent-purple);
  }

  .timeline-node:hover .read-link {
    color: var(--accent-cyan);
  }

  /* Deploy Banner */
  .deploy-banner {
    padding: 2rem;
    border-radius: 16px;
    border-color: hsla(271, 91%, 65%, 0.15);
  }

  .deploy-content {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .v-icon {
    font-size: 2.5rem;
    color: var(--accent-purple);
    filter: drop-shadow(0 0 10px rgba(157, 78, 221, 0.3));
  }

  .deploy-banner h3 {
    font-size: 1.25rem;
    color: #fff;
    margin-bottom: 0.25rem;
  }

  .deploy-banner p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .main-title {
      font-size: 2.5rem;
    }
    
    .timeline-container {
      grid-template-columns: 1fr;
    }

    .deploy-content {
      flex-direction: column;
      text-align: center;
      gap: 1rem;
    }
  }
</style>
